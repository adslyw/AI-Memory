{
  "manifest_version": 3,
  "name": "M3U Player",
  "version": "1.0.0",
  "description": "M3U8 直播流播放器，支持频道列表管理和跨域播放",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["test.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
